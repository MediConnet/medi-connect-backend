# -----------------------------------------------------------------------------
# ARCHIVO DE CONFIGURACIÓN DE EJEMPLO (.env.example)
# Copia este archivo como .env y completa las variables correspondientes
# -----------------------------------------------------------------------------

# Base de datos (Prisma)
DATABASE_URL="postgresql://usuario:contraseña@servidor:puerto/nombre_bd?sslmode=require"

# -----------------------------------------------------------------------------
# ❌ REMOVER (Variables obsoletas de PayPhone)
# -----------------------------------------------------------------------------
# PAYPHONE_TOKEN="remueve_esta_variable"
# PAYPHONE_STORE_ID="remueve_esta_variable"

# -----------------------------------------------------------------------------
#  NUEVO: Integración de Nuvei (Paymentez Ecuador)
# -----------------------------------------------------------------------------
# Endpoint Base de Nuvei (Staging: https://ccapi-stg.paymentez.com | Producción: https://ccapi.paymentez.com)
NUVEI_BASE_URL="https://ccapi-stg.paymentez.com"

# Credenciales de Servidor (Server App Code / Server App Key)
NUVEI_SERVER_APP_CODE="NUVEISTG-EC-SERVER"
NUVEI_SERVER_APP_KEY="Kn9v6ICvoRXQozQG2rK92WtjG6l08a"

# Credenciales de Cliente Móvil (Client App Code / Client App Key)
NUVEI_CLIENT_APP_CODE="NUVEISTG-EC-CLIENT"
NUVEI_CLIENT_APP_KEY="rvpKAv2tc49x6YL38fvtv5jJxRRiPs"


# -----------------------------------------------------------------------------
# Otras configuraciones de la plataforma
# -----------------------------------------------------------------------------
# Configuración de correo (Resend / SMTP)
RESEND_API_KEY=re_ejemplo_key
RESEND_FROM_EMAIL=noreply@tudominio.com

# URL del Frontend Web
FRONTEND_URL=http://localhost:5173

# Almacenamiento de Imágenes (Cloudinary)
CLOUDINARY_CLOUD_NAME=nombre_de_nube
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Autenticación con Google
GOOGLE_CLIENT_ID=google_web_client_id
GOOGLE_IOS_CLIENT_ID=google_ios_client_id
